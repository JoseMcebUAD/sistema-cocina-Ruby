<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane id="apertura-caja-root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="320.0" prefWidth="460.0" stylesheets="@../../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Controller.popup.caja.AperturaCajaController">
   <center>
      <VBox id="apertura-container" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="confirmOrder-header-label" text="APERTURA DE CAJA" />

            <Label styleClass="confirmOrder-label" wrapText="true"
                   text="Para comenzar a operar, ingrese el monto inicial de dinero en caja." />

            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="confirmOrder-label" text="MONTO INICIAL ($):" />
                  <TextField fx:id="montoInicialField" prefHeight="40.0" prefWidth="180.0"
                             promptText="0.00" styleClass="confirmOrder-field-read" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>

            <Label fx:id="errorLabel" styleClass="error-label" text="" visible="false" managed="false" />

            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="abrirButton" mnemonicParsing="false"
                          styleClass="confirmOrder-btn-success" text="ABRIR CAJA">
                     <padding>
                        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                     </padding>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
