<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane id="cierre-caja-root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="520.0" stylesheets="@../../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Controller.popup.caja.CierreCajaController">
   <center>
      <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="15.0">
               <children>
                  <!-- Encabezado -->
                  <Label styleClass="confirmOrder-header-label" text="ARQUEO DE CAJA" />
                  <Label styleClass="confirmOrder-label" wrapText="true"
                         text="Ingrese la cantidad de billetes y monedas contados físicamente." />

                  <Separator />

                  <!-- Sección Billetes -->
                  <Label text="BILLETES" styleClass="confirmOrder-label">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>

                  <GridPane hgap="10.0" vgap="8.0">
                     <children>
                        <Label text="\$1,000" styleClass="confirmOrder-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="b1000" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label fx:id="sub1000" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="0" GridPane.columnIndex="2" />

                        <Label text="\$500" styleClass="confirmOrder-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="b500" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <Label fx:id="sub500" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="1" GridPane.columnIndex="2" />

                        <Label text="\$200" styleClass="confirmOrder-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="b200" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                        <Label fx:id="sub200" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="2" GridPane.columnIndex="2" />

                        <Label text="\$100" styleClass="confirmOrder-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <TextField fx:id="b100" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                        <Label fx:id="sub100" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="3" GridPane.columnIndex="2" />

                        <Label text="\$50" styleClass="confirmOrder-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <TextField fx:id="b50" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                        <Label fx:id="sub50" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="4" GridPane.columnIndex="2" />

                        <Label text="\$20" styleClass="confirmOrder-label" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                        <TextField fx:id="b20" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="5" GridPane.columnIndex="1" />
                        <Label fx:id="sub20b" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="5" GridPane.columnIndex="2" />
                     </children>
                     <padding><Insets left="10.0" /></padding>
                  </GridPane>

                  <Separator />

                  <!-- Sección Monedas -->
                  <Label text="MONEDAS" styleClass="confirmOrder-label">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>

                  <GridPane hgap="10.0" vgap="8.0">
                     <children>
                        <Label text="\$20" styleClass="confirmOrder-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="m20" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label fx:id="sub20m" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="0" GridPane.columnIndex="2" />

                        <Label text="\$10" styleClass="confirmOrder-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="m10" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <Label fx:id="sub10" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="1" GridPane.columnIndex="2" />

                        <Label text="\$5" styleClass="confirmOrder-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="m5" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                        <Label fx:id="sub5" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="2" GridPane.columnIndex="2" />

                        <Label text="\$2" styleClass="confirmOrder-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <TextField fx:id="m2" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                        <Label fx:id="sub2" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="3" GridPane.columnIndex="2" />

                        <Label text="\$1" styleClass="confirmOrder-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <TextField fx:id="m1" promptText="0" prefWidth="80.0" styleClass="confirmOrder-field-read" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                        <Label fx:id="sub1" text="= \$0.00" styleClass="confirmOrder-label" GridPane.rowIndex="4" GridPane.columnIndex="2" />
                     </children>
                     <padding><Insets left="10.0" /></padding>
                  </GridPane>

                  <Separator />

                  <!-- Total contado -->
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Label text="TOTAL CONTADO:" styleClass="confirmOrder-label">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label fx:id="totalContadoLabel" text="\$0.00" styleClass="confirmOrder-field-total">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                     </children>
                  </HBox>

                  <!-- Observaciones (inicialmente oculto, obligatorio si hay diferencia) -->
                  <VBox fx:id="observacionesBox" spacing="5.0" visible="false" managed="false">
                     <children>
                        <Label styleClass="error-label"
                               text="Se detectó una diferencia. Justifique el descuadre (obligatorio):" />
                        <TextArea fx:id="observacionesArea" prefHeight="80.0" wrapText="true"
                                  promptText="Ingrese la razón del descuadre..." />
                     </children>
                  </VBox>

                  <!-- Botón confirmar -->
                  <HBox alignment="CENTER" spacing="20.0">
                     <children>
                        <Button fx:id="confirmarButton" mnemonicParsing="false"
                                styleClass="confirmOrder-btn-success" text="CONFIRMAR CIERRE">
                           <padding>
                              <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                           </padding>
                        </Button>
                        <Button fx:id="cancelarButton" mnemonicParsing="false"
                                styleClass="confirmOrder-btn-back" text="CANCELAR">
                           <padding>
                              <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                           </padding>
                        </Button>
                     </children>
                     <VBox.margin><Insets top="5.0" bottom="10.0" /></VBox.margin>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
